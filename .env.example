# Anthropic Claude API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Evolution API base URL (e.g., https://my-evolution.up.railway.app)
EVOLUTION_URL=

# Evolution API authentication key (AUTHENTICATION_API_KEY in Evolution config)
EVOLUTION_API_KEY=

# The Evolution instance name you created (e.g., my-bot)
EVOLUTION_INSTANCE_NAME=

# HTTP port the Express server listens on
PORT=3000
